library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity Sensor_Project is
    port (
        clk          : in  std_logic;                    -- Clock 50 MHz
        sensor_input : in  std_logic;                    -- الخيط اللي جاي من الكابتور
        led_out      : out std_logic;                    -- باش نشوفو النتيجة فالبولة
        data_out     : out std_logic_vector(7 downto 0)  -- باش نشوفو القيمة (ModelSim)
    );
end entity Sensor_Project;

architecture rtl of Sensor_Project is
    -- إشارة باش نحسبو شحال من مرة "تيرّا" الكابتور
    signal counter : unsigned(7 downto 0) := (others => '0');
    signal last_state : std_logic := '0';
begin

    process(clk)
    begin
        if rising_edge(clk) then
            -- نخبّيو الحالة القديمة باش نعرفو واش تبدلات
            last_state <= sensor_input;

            -- إلا كانت 0 ولات 1 (Front montant)
            if (last_state = '0' and sensor_input = '1') then
                counter <= counter + 1; -- حسب واحد
                led_out <= '1';         -- شعّل البولة
            else
                led_out <= '0';         -- طفي البولة
            end if;
        end if;
    end process;

    -- نخرجو الحساب باش يبان فـ ModelSim
    data_out <= std_logic_vector(counter);

end architecture rtl;